# Database
POSTGRES_USER=REPLACE_WITH_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
POSTGRES_DB=REPLACE_WITH_DB_NAME
DATABASE_URL=postgresql://REPLACE_WITH_DB_USER:REPLACE_WITH_DB_PASSWORD@localhost:5432/REPLACE_WITH_DB_NAME

# App auth
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES

# GitHub OAuth
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# 42 OAuth
FORTYTWO_CLIENT_ID=REPLACE_WITH_42_CLIENT_ID
FORTYTWO_CLIENT_SECRET=REPLACE_WITH_42_CLIENT_SECRET
FORTYTWO_CALLBACK_URL=http://localhost:3001/auth/42/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Mail
MAIL_USER=REPLACE_WITH_SMTP_USERNAME
MAIL_PASS=REPLACE_WITH_SMTP_PASSWORD

# API Keys
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# Seed script
SEED_SCRIPT_KEY=REPLACE_WITH_A_RANDOM_SEED_KEY
